// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            Int          @id @default(autoincrement())
  email         String       @unique
  password      String
  name          String?
  roleId        Int
  role          Role         @relation(fields: [roleId], references: [id])
  status        String       @default("active")
  language      String       @default("ar")
  darkMode      Boolean      @default(false)
  image         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  // Relationships
  associationId Int?
  association   Association? @relation(fields: [associationId], references: [id], onDelete: SetNull)
  marketerId    Int?
  marketer      Marketer?    @relation(fields: [marketerId], references: [id], onDelete: SetNull)
  beneficiaryId Int?
  beneficiary   Beneficiary? @relation(fields: [beneficiaryId], references: [id], onDelete: SetNull)
  permissions   UserPermission[]
  notifications Notification[]
  assignedBeneficiaries Beneficiary[] @relation("ResearcherBeneficiaries")
}

enum RoleType {
  superadmin
  admin
  user
}

model Role {
  id          Int              @id @default(autoincrement())
  name        String           @unique
  nameAr      String?
  type        RoleType         @default(user)
  permissions RolePermission[]
  users       User[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
}

model Screen {
  id              Int              @id @default(autoincrement())
  name            String           @unique
  nameAr          String?
  path            String           @unique
  permissions     RolePermission[]
  userPermissions UserPermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model RolePermission {
  id        Int      @id @default(autoincrement())
  roleId    Int
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  screenId  Int
  screen    Screen   @relation(fields: [screenId], references: [id], onDelete: Cascade)
  actions   String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([roleId, screenId])
}

model Association {
  id        Int      @id @default(autoincrement())
  name      String
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model Marketer {
  id        Int      @id @default(autoincrement())
  name      String
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  users     User[]
}

model Beneficiary {
  id             Int             @id @default(autoincrement())
  name           String
  status         String?
  notes          String?
  image          String?
  nationalId     String?         @unique
  phone          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  users          User[]
  socialResearch SocialResearch?

  // Relationships
  researcherId   Int?
  researcher     User?           @relation("ResearcherBeneficiaries", fields: [researcherId], references: [id], onDelete: SetNull)
}

model SocialResearch {
  id                 String      @id @default(uuid())
  beneficiaryId      Int         @unique
  beneficiary        Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  fileNumber         String      @unique
  visitDate          DateTime    @default(now())
  researcherName     String
  applicationStatus  String      // NEW, UPDATE, REFERRED
  lastUpdateDate     DateTime?

  // Financial Summary
  totalIncome        Float       @default(0.0)
  totalExpenses      Float       @default(0.0)
  netRemainingIncome Float       @default(0.0)

  // Environment & Housing
  environmentType    String
  housingType        String
  housingOwnership   String

  // Opinions & Recommendations
  researcherOpinions Json        // Structured JSON for all opinions (sections 1, 2, 3, 4, 5, 6, finalRecommendation, caseCategory)
  needsAssessment    Json        // Structured JSON for needs (basicNeedsJson, developmentalNeedsJson, medical, financial sponsorship, etc.)
  proposedPrograms   Json        // Donation packages (proposedDonationPrograms)
  
  // Media Attachments
  images             Json        // Object/Array containing outer, livingRoom, kitchen, roof repair urls
  approvals          Json?       // Approvals JSON

  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
  dependents         Dependent[]
}

model Dependent {
  id               String         @id @default(uuid())
  socialResearchId String
  socialResearch   SocialResearch @relation(fields: [socialResearchId], references: [id], onDelete: Cascade)
  name             String
  relationship     String
  birthYear        String
  educationLevel   String
  healthStatus     String
  socialStatus     String
  employmentStatus String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

enum ApplicationStatus {
  NEW
  UPDATE
  REFERRED
}

enum MaritalStatus {
  MARRIED
  WIDOW
  DIVORCED
  ABANDONED
  SINGLE
}

enum HealthStatus {
  HEALTHY
  DISABLED
  SICK
}

enum EnvironmentType {
  HIGRAH
  BADIAH
  VILLAGE
  GOVERNORATE
  CITY
}

enum HousingType {
  POPULAR
  APARTMENT
  VILLA_FLOOR
  ANNEX
}

enum HousingOwnership {
  RENT
  OWNED
  INHERITED
  ENDOWMENT
}

enum CaseCategory {
  URGENT_PRIORITY
  MEDIUM_PRIORITY
  NOT_ELIGIBLE
}

enum StatusCategory {
  HIGH
  MEDIUM
  REJECTED
}

model UserPermission {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  screenId  Int
  screen    Screen   @relation(fields: [screenId], references: [id], onDelete: Cascade)
  actions   String[] @default([])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, screenId])
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  titleAr   String?
  message   String
  messageAr String?
  read      Boolean  @default(false)
  type      String   @default("info") // info, success, warning, error
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SystemEvent {
  id        String   @id @default(cuid())
  eventType String
  userId    Int?
  payload   Json
  ipAddress String?
  createdAt DateTime @default(now())

  @@index([eventType])
  @@index([userId])
  @@index([createdAt])
}
